{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quolab Demo Variables",
  "description": "Variables de personalización para generar una demo web automática",
  "type": "object",
  "required": ["nombre_negocio", "rubro", "ciudad", "telefono"],
  "properties": {
    "nombre_negocio":   { "type": "string", "example": "Restaurante El Huaso" },
    "rubro":            { "type": "string", "example": "Restaurante" },
    "ciudad":           { "type": "string", "example": "Santiago" },
    "telefono":         { "type": "string", "example": "+56 9 1234 5678" },
    "email":            { "type": "string", "example": "contacto@elhuaso.cl" },
    "direccion":        { "type": "string", "example": "Av. Providencia 1234, Santiago" },
    "slogan":           { "type": "string", "example": "El sabor de siempre, en tu mesa" },
    "descripcion":      { "type": "string", "example": "Llevamos 15 años entregando la mejor cocina chilena tradicional en el corazón de Santiago." },
    "servicio_1_titulo":{ "type": "string", "example": "Almuerzo ejecutivo" },
    "servicio_1_desc":  { "type": "string", "example": "Menú completo de lunes a viernes con entrada, plato de fondo y postre." },
    "servicio_1_icono": { "type": "string", "example": "🍽️" },
    "servicio_2_titulo":{ "type": "string", "example": "Cenas especiales" },
    "servicio_2_desc":  { "type": "string", "example": "Reservas para eventos, cumpleaños y celebraciones con menú personalizado." },
    "servicio_2_icono": { "type": "string", "example": "🎉" },
    "servicio_3_titulo":{ "type": "string", "example": "Delivery a domicilio" },
    "servicio_3_desc":  { "type": "string", "example": "Llevamos nuestros platos favoritos directo a tu puerta, todos los días." },
    "servicio_3_icono": { "type": "string", "example": "🚗" },
    "color_primario":   { "type": "string", "example": "#1A56DB", "description": "Color principal de la marca" },
    "color_secundario": { "type": "string", "example": "#0E3A9E", "description": "Versión más oscura del primario" },
    "color_acento":     { "type": "string", "example": "#F97316", "description": "Color de contraste para CTAs" },
    "hero_variante":    { "type": "string", "enum": ["A","B","C"], "description": "Variante de diseño del bloque Hero" },
    "servicios_variante":{ "type": "string", "enum": ["A","B","C"] },
    "testimonios_variante":{ "type": "string", "enum": ["A","B","C"] },
    "nosotros_variante":{ "type": "string", "enum": ["A","B","C"] },
    "cta_variante":     { "type": "string", "enum": ["A","B","C"] },
    "contacto_variante":{ "type": "string", "enum": ["A","B","C"] },
    "og_image_url":     { "type": "string", "description": "URL absoluta de imagen 1200x630px para preview WhatsApp/redes" },
    "demo_url":         { "type": "string", "description": "URL final de la demo en Cloudflare Pages" }
  }
}
